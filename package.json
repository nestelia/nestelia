{
  "name": "nestelia",
  "version": "1.9.0",
  "description": "Modular framework with decorators, dependency injection, modules and lifecycle hooks for Elysia",
  "type": "module",
  "author": {
    "name": "Islam Kiiasov",
    "url": "https://github.com/kiyasov"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nestelia/nestelia"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./scheduler": {
      "import": "./dist/esm/packages/scheduler/src/index.js",
      "require": "./dist/cjs/packages/scheduler/src/index.js",
      "types": "./dist/types/packages/scheduler/src/index.d.ts"
    },
    "./microservices": {
      "import": "./dist/esm/packages/microservices/src/index.js",
      "require": "./dist/cjs/packages/microservices/src/index.js",
      "types": "./dist/types/packages/microservices/src/index.d.ts"
    },
    "./apollo": {
      "import": "./dist/esm/packages/apollo/src/index.js",
      "require": "./dist/cjs/packages/apollo/src/index.js",
      "types": "./dist/types/packages/apollo/src/index.d.ts"
    },
    "./passport": {
      "import": "./dist/esm/packages/passport/src/index.js",
      "require": "./dist/cjs/packages/passport/src/index.js",
      "types": "./dist/types/packages/passport/src/index.d.ts"
    },
    "./testing": {
      "import": "./dist/esm/packages/testing/src/index.js",
      "require": "./dist/cjs/packages/testing/src/index.js",
      "types": "./dist/types/packages/testing/src/index.d.ts"
    },
    "./cache": {
      "import": "./dist/esm/packages/cache/src/index.js",
      "require": "./dist/cjs/packages/cache/src/index.js",
      "types": "./dist/types/packages/cache/src/index.d.ts"
    },
    "./rabbitmq": {
      "import": "./dist/esm/packages/rabbitmq/src/index.js",
      "require": "./dist/cjs/packages/rabbitmq/src/index.js",
      "types": "./dist/types/packages/rabbitmq/src/index.d.ts"
    },
    "./graphql-pubsub": {
      "import": "./dist/esm/packages/graphql-pubsub/src/index.js",
      "require": "./dist/cjs/packages/graphql-pubsub/src/index.js",
      "types": "./dist/types/packages/graphql-pubsub/src/index.d.ts"
    },
    "./drizzle": {
      "import": "./dist/esm/packages/drizzle/src/index.js",
      "require": "./dist/cjs/packages/drizzle/src/index.js",
      "types": "./dist/types/packages/drizzle/src/index.d.ts"
    },
    "./event-emitter": {
      "import": "./dist/esm/packages/event-emitter/src/index.js",
      "require": "./dist/cjs/packages/event-emitter/src/index.js",
      "types": "./dist/types/packages/event-emitter/src/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "nestelia-gen": "./bin/nestelia-gen.ts"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "prepublishOnly": "bun run test && bun run typecheck && bun run build",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags",
    "docs:og": "bun scripts/gen-og.ts",
    "docs:dev": "cd docs && bun run dev",
    "docs:build": "bun run docs:og && cd docs && bun run build",
    "docs:preview": "cd docs && bun run preview",
    "bench": "bun benchmark/run.ts",
    "docs:api": "bunx typedoc",
    "prepare": "husky"
  },
  "dependencies": {
    "cron": "^4.4.0"
  },
  "peerDependencies": {
    "elysia": "^1.0.0",
    "reflect-metadata": "^0.2.0",
    "class-validator": "^0.14.0 || ^0.15.0",
    "class-transformer": "^0.5.0",
    "@apollo/server": "^5.0.0",
    "@graphql-tools/schema": "^10.0.0",
    "graphql": "^16.0.0",
    "graphql-ws": "^5.0.0 || ^6.0.0",
    "cache-manager": "^7.0.0",
    "cacheable": "^2.0.0",
    "keyv": "^5.0.0",
    "ioredis": "^5.0.0",
    "rxjs": "^7.0.0",
    "passport": "^0.7.0",
    "amqplib": "^0.10.0",
    "amqp-connection-manager": "^4.0.0",
    "drizzle-orm": ">=0.30.0"
  },
  "peerDependenciesMeta": {
    "class-validator": {
      "optional": true
    },
    "class-transformer": {
      "optional": true
    },
    "@apollo/server": {
      "optional": true
    },
    "@graphql-tools/schema": {
      "optional": true
    },
    "graphql": {
      "optional": true
    },
    "graphql-ws": {
      "optional": true
    },
    "cache-manager": {
      "optional": true
    },
    "cacheable": {
      "optional": true
    },
    "keyv": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    },
    "passport": {
      "optional": true
    },
    "amqplib": {
      "optional": true
    },
    "amqp-connection-manager": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "elysia": {
      "optional": false
    },
    "reflect-metadata": {
      "optional": false
    }
  },
  "devDependencies": {
    "@apollo/server": "^5.5.0",
    "@elysiajs/eden": "^1.4.9",
    "@graphql-tools/schema": "^10.0.32",
    "@resvg/resvg-js": "^2.6.2",
    "@types/amqplib": "^0.10.8",
    "@types/bun": "^1.3.12",
    "@types/passport": "^1.0.17",
    "amqp-connection-manager": "^4.1.14",
    "amqplib": "^0.10.9",
    "cache-manager": "^7.2.8",
    "cacheable": "^2.3.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "graphql": "^16.13.2",
    "graphql-ws": "^6.0.8",
    "husky": "^9.1.7",
    "ioredis": "^5.10.1",
    "keyv": "^5.6.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "passport": "^0.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ts-morph": "^28.0.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "elysia",
    "decorators",
    "dependency-injection",
    "bun",
    "typescript",
    "controllers",
    "modules",
    "guards",
    "interceptors",
    "pipes",
    "middleware"
  ]
}
